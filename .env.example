# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/trendtracker
# MongoDB
MONGODB_URI=mongodb://localhost:27017/trendtracker

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API Keys - Trend Detection
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

YOUTUBE_API_KEY=your_youtube_api_key

GOOGLE_TRENDS_API_KEY=your_google_trends_api_key

# API Keys - Content Generation
OPENAI_API_KEY=your_openai_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key
STABILITY_AI_API_KEY=your_stability_ai_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=trendtracker-assets

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d

# Content Generation Settings
MAX_CONTENT_LENGTH=2000
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,ja,zh

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_IMAGE_GENERATION=true
ENABLE_VIDEO_GENERATION=true
ENABLE_VOICE_GENERATION=true
ENABLE_ETHICAL_FILTERS=true
